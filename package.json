{
  "name": "controle-fazendas",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema SaaS multi-fazenda para controle de áreas e processos",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @controle-fazendas/database generate",
    "db:migrate": "pnpm --filter @controle-fazendas/database migrate",
    "db:seed": "pnpm --filter @controle-fazendas/database seed",
    "db:studio": "pnpm --filter @controle-fazendas/database studio"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
