# Copie para o Railway (Variables) — NÃO commite valores reais

# PostgreSQL (no Railway: referencie o plugin Postgres → DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/controle_fazendas

# JWT — gere strings longas e aleatórias (ex.: openssl rand -base64 32)
JWT_SECRET=troque-por-uma-string-longa-aleatoria
JWT_REFRESH_SECRET=troque-por-outra-string-longa-aleatoria
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# URL exata do frontend no Vercel (sem barra no final)
CORS_ORIGIN=https://controle-fazendas-web.vercel.app

NODE_ENV=production
# PORT — o Railway define automaticamente; não precisa preencher

# Geração de banners Hub Fazendas (Google Gemini)
# Obtenha a chave em https://aistudio.google.com/apikey
# IMPORTANTE: geração de imagens (gemini-2.5-flash-image) exige billing ativo no projeto Google Cloud.
# O plano gratuito tem cota 0 para este recurso — ative em AI Studio → Configurações → Billing.
GEMINI_API_KEY=
IMAGE_GEN_PROVIDER=gemini
IMAGE_GEN_MODEL=gemini-2.5-flash-image
IMAGE_GEN_TIMEOUT_MS=120000
